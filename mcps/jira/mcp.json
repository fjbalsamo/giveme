{
  "mcpServers": {
    "jira": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@anthropic-labs/mcp-jira"],
      "env": {
        "JIRA_URL": "${GIVEME_JIRA_URL}",
        "JIRA_EMAIL": "${GIVEME_JIRA_EMAIL}",
        "JIRA_API_TOKEN": "${GIVEME_JIRA_API_TOKEN}"
      }
    }
  }
}